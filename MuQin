        "                   <div className=\"flex gap-12 px-6 items-center\">\n",
        "                      <div className=\"text-left border-r border-white/10 pr-12\">\n",
        "                         <p className=\"text-[9px] font-black text-stone-500 uppercase tracking-widest\">總櫃數</p>\n",
        "                         <h4 className=\"text-2xl font-serif font-black text-white\">{cabinets.length}</h4>\n",
        "                      </div>\n",
        "                      <div className=\"text-left\">\n",

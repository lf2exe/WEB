        "                                <BilingualLabel cn=\"門/抽數\" en=\"Qty\" />\n",
        "                                <input type=\"number\" className=\"w-14 h-14 border rounded-full font-serif text-xl text-center shadow-inner outline-none bg-stone-50\" value={cab.doorCount} onChange={e=>updateCabinet(cab.id, 'doorCount', Number(e.target.value))} />\n",
        "                             </div>\n",
        "                             <div className=\"flex-1 space-y-4\">\n",
        "                                <select className=\"w-full border-b font-bold text-[11px] py-1 outline-none\" value={cab.handleType} onChange={e=>updateCabinet(cab.id, 'handleType', e.target.value)}>{HANDLE_TYPES.map(h=><option key={h.id} value={h.id}>{h.name}</option>)}</select>\n",

        "                      </div>\n",
        "                   </div>\n",
        "                   <button onClick={askGeminiAnalysis} disabled={cabinets.length === 0 || aiLoading} className=\"px-10 py-4 rounded-full font-black flex items-center gap-3 text-[10px] tracking-widest bg-stone-800 text-white hover:bg-stone-700 border border-white/10\">\n",
        "                      {aiLoading ? <Loader2 size={16} className=\"animate-spin\" /> : <Sparkles size={16} />} 智能專案分析\n",
        "                   </button>\n",
        "                </div>\n",
        "             </div>\n",
        "          </div>\n",
        "        )}\n",
        "      </div>\n",
        "\n",
        "      {/* AI Modal */}\n",
        "      {showAiModal && (\n",
        "        <div className=\"fixed inset-0 z-[300] flex items-center justify-center p-6 bg-black/80 backdrop-blur-md animate-in fade-in\">\n",
        "           <div className=\"bg-white w-full max-w-3xl rounded-3xl shadow-2xl border-2 overflow-hidden flex flex-col max-h-[85vh]\" style={{ borderColor: MUQIN_STYLE.gold }}>\n",
        "              <div className=\"p-8 flex justify-between items-center bg-stone-900 text-white border-b-2\" style={{ borderColor: MUQIN_STYLE.gold }}>\n",
        "                 <div className=\"flex items-center gap-4\"><Sparkles size={24} className=\"text-amber-400 animate-pulse\" /><h2 className=\"text-xl font-serif font-black tracking-widest uppercase\">Muqin AI Analysis</h2></div>\n",
        "                 <button onClick={() => setShowAiModal(false)}><X size={24} /></button>\n",

        "                 )}\n",
        "              </div>\n",
        "              <div className=\"p-6 border-t bg-stone-50 flex justify-center\"><button onClick={() => setShowAiModal(false)} className=\"px-16 py-3 rounded-full font-black text-[10px] uppercase text-white bg-stone-800\">關閉</button></div>\n",
        "           </div>\n",
        "        </div>\n",
        "      )}\n",
        "\n",
        "      <style>{`\n",
        "        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Montserrat:wght@400;700;900&display=swap');\n",

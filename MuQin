        "                    <div className=\"p-8 grid grid-cols-1 lg:grid-cols-4 gap-10\">\n",
        "                       <div className=\"space-y-6\">\n",
        "                          <BilingualLabel cn=\"01. 尺寸規格\" en=\"Dimensions\" />\n",

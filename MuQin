        "                             <select className=\"w-full border-b font-bold text-[11px] py-1 outline-none\" value={cab.doorSeries} onChange={e=>updateCabinet(cab.id, 'doorSeries', e.target.value)}>{priceTable.map(s=><option key={s.id} value={s.id}>{s.name} (門片)</option>)}</select>\n",
        "                             {cab.type === 'desk' && (\n",
        "                               <select className=\"w-full border-b font-bold text-[11px] py-1 outline-none\" value={cab.deskBackType} onChange={e=>updateCabinet(cab.id, 'deskBackType', e.target.value)}>{DESK_BACK_TYPES.map(t=><option key={t.id} value={t.id}>{t.name}</option>)}</select>\n",
        "                             )}\n",
        "                          </div>\n",
        "                       </div>\n",

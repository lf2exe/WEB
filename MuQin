        "                             <div className=\"flex justify-between\"><span>Facade</span><span>${Math.round(bom.doorT).toLocaleString()}</span></div>\n",
        "                             <div className=\"flex justify-between text-amber-400\"><span>Hardware</span><span>${Math.round(bom.hardwareT).toLocaleString()}</span></div>\n",

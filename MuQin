        "                          <div className=\"mt-8 pt-4 border-t border-white/10 text-center\">\n",
        "                             <h2 className=\"text-4xl font-serif font-black tracking-tighter\" style={{ color: MUQIN_STYLE.gold }}>${bom.discountedTotal.toLocaleString()}</h2>\n",
        "                          </div>\n",
        "                       </div>\n",
        "                    </div>\n",
        "                 </div>\n",
        "               );\n",
        "             })}\n",

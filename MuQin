        "import React, { useState, useEffect, useMemo, useRef } from 'react';\n",
        "import { initializeApp } from 'firebase/app';\n",
        "import { getAuth, onAuthStateChanged, signInAnonymously, signInWithCustomToken } from 'firebase/auth';\n",
        "import { getFirestore, doc, setDoc, getDoc, collection } from 'firebase/firestore';\n",
        "import { Plus, Trash2, Printer, Save, Settings, Package, ClipboardList, Box, Maximize2, Crown, MapPin, Calendar, UserCheck, Sparkles, Loader2, X, AlertCircle, Download, ChevronDown, CloudUpload, FileType, ExternalLink } from 'lucide-react';\n",
        "\n",
        "// --- Firebase 基礎配置 ---\n",
        "const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {\n",
        "  apiKey: \"\",\n",
        "  authDomain: \"\",\n",
        "  projectId: \"\",\n",
        "  storageBucket: \"\",\n",
        "  messagingSenderId: \"\",\n",
        "  appId: \"\"\n",
        "};\n",
        "\n",
        "const app = initializeApp(firebaseConfig);\n",
        "const auth = getAuth(app);\n",
        "const db = getFirestore(app);\n",
        "const appId = typeof __app_id !== 'undefined' ? __app_id : 'muqin-quote-app';\n",
        "\n",
        "// --- 系統常數 (依據御馨 115/04/26 價目表) ---\n",
        "const BOARD_THICKNESS = 18;\n",
        "const CAI_UNIT = 91809;\n",
        "const apiKey = \"\"; // Gemini API Key\n",
        "\n",
        "const MUQIN_STYLE = {\n",
        "  espresso: '#46392E',\n",
        "  vachetta: '#BC935F',\n",
        "  gold: '#EAC15A',\n",
        "  ivory: '#F9F7F2',\n",
        "  border: '#D4C5B9'\n",
        "};\n",
        "\n",
        "const INITIAL_PRICE_TABLE = [\n",
        "  { id: 'PH', name: 'PH系列', back: 95, carcass: 115, door: 130, table25: 220, table50: 420 },\n",
        "  { id: 'PF', name: 'PF系列', back: 110, carcass: 125, door: 140, table25: 250, table50: 440 },\n",
        "  { id: 'PC', name: 'PC系列', back: 115, carcass: 135, door: 150, table25: 270, table50: 450 },\n",
        "  { id: 'PB', name: 'PB系列', back: 120, carcass: 145, door: 160, table25: 290, table50: 460 },\n",
        "  { id: 'PA', name: 'PA系列', back: 150, carcass: 170, door: 180, table25: 370, table50: 540 },\n",
        "  { id: 'YW102', name: '白色發泡板 (YW102)', back: 110, carcass: 250, door: 280, table25: 600, table50: 900 }\n",
        "];\n",
        "\n",
        "const CABINET_TYPES = [\n",
        "  { id: 'standard', name: '標準門櫃', description: 'STANDARD CABINET' },\n",
        "  { id: 'open', name: '開放櫃', description: 'OPEN SHELVES' },\n",
        "  { id: 'desk', name: '書桌/檯面', description: 'DESK & TABLE' },\n",
        "  { id: 'deco', name: '獨立飾板/假門', description: 'DECORATIVE PANEL' }\n",
        "];\n",
        "\n",
        "const HANDLE_TYPES = [\n",
        "  { id: 'none', name: '無把手 (拍拍手)', priceUnder: 150, priceOver: 150, type: 'fixed' },\n",
        "  { id: 'z-handle', name: '單Z把手', priceUnder: 800, priceOver: 1000, type: 'step' },\n",
        "  { id: 'j-handle', name: 'J型把手', priceUnder: 900, priceOver: 1200, type: 'step' },\n",
        "  { id: 'slope-45', name: '45度斜把手', pricePerCm: 4, type: 'cm' }\n",
        "];\n",
        "\n",
        "const DESK_BACK_TYPES = [\n",
        "  { id: 'none', name: '無背板' },\n",
        "  { id: '擋板-30', name: '背擋板 (30cm)' },\n",
        "  { id: '擋板-全', name: '全背擋板' }\n",
        "];\n",
        "\n",
        "const EXPOSED_SIDE_OPTIONS = [\n",
        "  { id: 'none', name: '無見光面 / NONE' },\n",
        "  { id: 'left', name: '左見光 / LEFT EXPOSED' },\n",
        "  { id: 'right', name: '右見光 / RIGHT EXPOSED' },\n",
        "  { id: 'both', name: '兩側見光 / BOTH EXPOSED' }\n",
        "];\n",
        "\n",
        "const BilingualLabel = ({ cn, en }) => (\n",
        "  <div className=\"flex flex-col mb-1.5 leading-tight select-none\">\n",
        "    <span className=\"text-[10px] font-black tracking-tight\" style={{ color: MUQIN_STYLE.espresso }}>{cn}</span>\n",
        "    <span className=\"text-[7px] font-bold uppercase tracking-widest opacity-40\" style={{ color: MUQIN_STYLE.vachetta }}>{en}</span>\n",
        "  </div>\n",
        ");\n",
        "\n",
        "const App = () => {\n",
        "  const today = new Date().toISOString().split('T')[0];\n",
        "  const [user, setUser] = useState(null);\n",
        "  const [customer, setCustomer] = useState({\n",
        "    name: '基隆武崙街周公館',\n",
        "    contact: '周先生',\n",
        "    address: '基隆市安樂區',\n",
        "    date: today,\n",
        "    discount: 0.6\n",
        "  });\n",
        "  const [cabinets, setCabinets] = useState([]);\n",
        "  const [priceTable, setPriceTable] = useState(INITIAL_PRICE_TABLE);\n",
        "  const [viewMode, setViewMode] = useState('quote');\n",
        "\n",
        "  const [aiLoading, setAiLoading] = useState(false);\n",
        "  const [aiResponse, setAiResponse] = useState(\"\");\n",
        "  const [showAiModal, setShowAiModal] = useState(false);\n",
        "  const [saveStatus, setSaveStatus] = useState({ show: false, msg: '', type: 'loading' });\n",
        "  const [isSaveMenuOpen, setIsSaveMenuOpen] = useState(false);\n",
        "  const saveMenuRef = useRef(null);\n",
        "\n",
        "  // --- 初始化驗證 ---\n",
        "  useEffect(() => {\n",
        "    const initAuth = async () => {\n",
        "      try {\n",
        "        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {\n",
        "          await signInWithCustomToken(auth, __initial_auth_token);\n",
        "        } else {\n",
        "          await signInAnonymously(auth);\n",
        "        }\n",
        "      } catch (err) { console.error(\"Auth error\", err); }\n",
        "    };\n",
        "    initAuth();\n",
        "    const unsubscribe = onAuthStateChanged(auth, setUser);\n",
        "    return () => unsubscribe();\n",
        "  }, []);\n",
        "\n",
        "  // --- 自動載入草稿 ---\n",
        "  useEffect(() => {\n",
        "    if (!user) return;\n",
        "    const loadDraft = async () => {\n",
        "      const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'draft');\n",
        "      const docSnap = await getDoc(docRef);\n",
        "      if (docSnap.exists()) {\n",
        "        const data = docSnap.data();\n",
        "        if (data.customer) setCustomer(data.customer);\n",
        "        if (data.cabinets) setCabinets(data.cabinets);\n",
        "        if (data.priceTable) setPriceTable(data.priceTable);\n",
        "      }\n",
        "    };\n",
        "    loadDraft();\n",
        "  }, [user]);\n",
        "\n",
        "  // --- 點擊外部關閉選單 ---\n",
        "  useEffect(() => {\n",
        "    const handleClickOutside = (event) => {\n",
        "      if (saveMenuRef.current && !saveMenuRef.current.contains(event.target)) setIsSaveMenuOpen(false);\n",
        "    };\n",
        "    document.addEventListener(\"mousedown\", handleClickOutside);\n",
        "    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n",
        "  }, []);\n",
        "\n",
        "  // --- 業務邏輯函數 ---\n",
        "  const addCabinet = (type = 'standard') => {\n",
        "    const newCabinet = {\n",
        "      id: Date.now(),\n",
        "      type,\n",
        "      name: `${CABINET_TYPES.find(t=>t.id===type).name} ${cabinets.length + 1}`,\n",
        "      w: type === 'deco' ? 100 : 600,\n",
        "      d: 560,\n",
        "      h: 2100,\n",
        "      carcassSeries: 'PH',\n",
        "      doorSeries: 'PC',\n",
        "      backSeries: 'PH',\n",
        "      doorCount: type === 'standard' ? 2 : (type === 'deco' ? 1 : 0),\n",
        "      shelfCount: 3,\n",
        "      isFloorCabinet: type !== 'desk' && type !== 'deco',\n",
        "      exposedSide: 'none',\n",
        "      handleType: 'z-handle',\n",
        "      deskBackType: '擋板-30'\n",
        "    };\n",
        "    setCabinets([...cabinets, newCabinet]);\n",
        "  };\n",
        "\n",
        "  const removeCabinet = (id) => setCabinets(cabinets.filter(c => c.id !== id));\n",
        "  const updateCabinet = (id, field, value) => setCabinets(cabinets.map(c => c.id === id ? { ...c, [field]: value } : c));\n",
        "\n",
        "  const calculateBOM = (cab) => {\n",
        "    const { w, d, h, doorCount, type, carcassSeries, doorSeries, backSeries, shelfCount, isFloorCabinet, exposedSide, deskBackType } = cab;\n",
        "    const def = { name: '未知', back: 0, carcass: 0, door: 0 };\n",
        "    const cP = priceTable.find(s => s.id === carcassSeries) || def;\n",
        "    const dP = priceTable.find(s => s.id === doorSeries) || def;\n",
        "    const bP = priceTable.find(s => s.id === backSeries) || def;\n",
        "    const getCai = (l, width) => Math.max(1, (l * width) / CAI_UNIT);\n",
        "\n",
        "    let parts = [];\n",
        "    let carT = 0, doorT = 0, backT = 0, decoT = 0;\n",
        "\n",
        "    if (type === 'deco') {\n",
        "      const cai = getCai(h, w) * doorCount;\n",
        "      decoT = cai * dP.door;\n",
        "      parts.push({ name: '裝飾假門', l: h, w: w, qty: doorCount, cat: 'door' });\n",
        "    } else {\n",
        "      parts = [\n",
        "        { name: '側板', l: h, w: d, qty: 2, cat: 'carcass' },\n",
        "        { name: '上下板', l: w - 36, w: d, qty: 2, cat: 'carcass' },\n",
        "        { name: '活動隔板', l: w - 38, w: d - 20, qty: shelfCount, cat: 'carcass' }\n",
        "      ];\n",
        "      if (type === 'desk') {\n",
        "        if (deskBackType === '擋板-30') parts.push({ name: '背擋板(30cm)', l: 300, w: w - 5, qty: 1, cat: 'back' });\n",
        "        else if (deskBackType === '擋板-全') parts.push({ name: '全背擋板', l: h - 5, w: w - 5, qty: 1, cat: 'back' });\n",
        "      } else {\n",
        "        parts.push({ name: '背板', l: h - 5, w: w - 5, qty: 1, cat: 'back' });\n",
        "      }\n",
        "      if (type === 'standard') parts.push({ name: '門片', l: h - 4, w: (w / doorCount) - 3, qty: doorCount, cat: 'door' });\n",
        "      if (exposedSide !== 'none') {\n",
        "        const qty = exposedSide === 'both' ? 2 : 1;\n",
        "        const cai = getCai(h, d) * qty;\n",
        "        decoT = cai * dP.door;\n",
        "        parts.push({ name: '側見光飾板', l: h, w: d, qty, cat: 'door' });\n",
        "      }\n",
        "      if (isFloorCabinet) parts.push({ name: '踢腳板', l: w, w: 100, qty: 1, cat: 'carcass' });\n",
        "    }\n",
        "\n",
        "    parts.forEach(p => {\n",
        "      const cai = getCai(p.l, p.w) * p.qty;\n",
        "      if (p.cat === 'carcass') carT += cai * cP.carcass;\n",
        "      if (p.cat === 'door' && type !== 'deco' && !p.name.includes('見光')) doorT += cai * dP.door;\n",
        "      if (p.cat === 'back') backT += cai * bP.back;\n",
        "    });\n",
        "\n",
        "    const hI = HANDLE_TYPES.find(ht => ht.id === cab.handleType) || HANDLE_TYPES[0];\n",
        "    const isOver = h > 1000 || w > 1000;\n",
        "    const hPrice = hI.type === 'step' ? (isOver ? hI.priceOver : hI.priceUnder) : (hI.type === 'cm' ? hI.pricePerCm * (h/10) : hI.priceUnder);\n",
        "    const hardwareT = (hPrice * doorCount) + (isFloorCabinet ? 18 * 4 : 0);\n",
        "\n",
        "    const rawTotal = carT + doorT + backT + decoT + hardwareT;\n",
        "    return { parts, carT, doorT, backT, decoT, hardwareT, rawTotal, discountedTotal: Math.round(rawTotal * customer.discount) };\n",
        "  };\n",
        "\n",
        "  const grandTotal = useMemo(() => cabinets.reduce((sum, c) => sum + calculateBOM(c).discountedTotal, 0), [cabinets, customer.discount, priceTable]);\n",
        "\n",
        "  // --- 儲存與分析函數 ---\n",
        "  const askGeminiAnalysis = async () => {\n",
        "    if (cabinets.length === 0) return;\n",
        "    setAiLoading(true);\n",
        "    setShowAiModal(true);\n",
        "    const cabinetData = cabinets.map(c => ({\n",
        "      名稱: c.name,\n",
        "      尺寸: `${c.w}x${c.d}x${c.h}`,\n",
        "      金額: calculateBOM(c).discountedTotal\n",
        "    }));\n",
        "    const userQuery = `分析沐勤專案報價單：${JSON.stringify(cabinetData)}，全案總計 ${grandTotal} 元。請提供精品美學建議。`;\n",
        "    const systemPrompt = \"你是一位精通精品系統櫃設計與計價的沐勤品牌顧問。\";\n",
        "    try {\n",
        "      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {\n",
        "        method: 'POST',\n",
        "        headers: { 'Content-Type': 'application/json' },\n",
        "        body: JSON.stringify({ contents: [{ parts: [{ text: userQuery }] }], systemInstruction: { parts: [{ text: systemPrompt }] } })\n",
        "      });\n",
        "      const result = await response.json();\n",
        "      setAiResponse(result.candidates?.[0]?.content?.parts?.[0]?.text || \"分析超時，請重新點擊。\");\n",
        "    } catch (err) { setAiResponse(\"無法連線至 AI 引擎。\"); }\n",
        "    finally { setAiLoading(false); }\n",
        "  };\n",
        "\n",
        "  const handleSaveDraft = async () => {\n",
        "    if (!user) return;\n",
        "    setIsSaveMenuOpen(false);\n",
        "    setSaveStatus({ show: true, msg: '同步雲端數據中...', type: 'loading' });\n",
        "    try {\n",
        "      const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'draft');\n",
        "      await setDoc(docRef, { customer, cabinets, priceTable, updatedAt: new Date().toISOString() });\n",
        "      setSaveStatus({ show: true, msg: '沐勤雲端備份成功', type: 'success' });\n",
        "      setTimeout(() => setSaveStatus(p => ({ ...p, show: false })), 3000);\n",
        "    } catch (e) { setSaveStatus({ show: true, msg: '儲存失敗', type: 'error' }); }\n",
        "  };\n",
        "\n",
        "  const handleExportJSON = () => {\n",
        "    setIsSaveMenuOpen(false);\n",
        "    const data = JSON.stringify({ customer, cabinets, priceTable, date: new Date().toISOString() }, null, 2);\n",
        "    const blob = new Blob([data], { type: 'application/json' });\n",
        "    const url = URL.createObjectURL(blob);\n",
        "    const link = document.createElement('a');\n",
        "    link.href = url;\n",
        "    link.download = `沐勤報價_${customer.name}.json`;\n",
        "    link.click();\n",
        "    URL.revokeObjectURL(url);\n",
        "    setSaveStatus({ show: true, msg: '檔案已下載至本機', type: 'success' });\n",
        "    setTimeout(() => setSaveStatus(p => ({ ...p, show: false })), 3000);\n",
        "  };\n",
        "\n",
        "  return (\n",
        "    <div className=\"min-h-screen p-4 md:p-6 font-sans transition-all\" style={{ backgroundColor: MUQIN_STYLE.ivory, color: MUQIN_STYLE.espresso }}>\n",
        "      <div className=\"max-w-6xl mx-auto\">\n",
        "        {/* Header */}\n",
        "        <div className=\"bg-white p-6 rounded-t-2xl shadow-lg border-b flex justify-between items-center no-print\" style={{ borderColor: MUQIN_STYLE.border }}>\n",
        "          <div className=\"flex items-center gap-4\">\n",
        "            <div className=\"p-3 rounded-full shadow-inner bg-stone-800 text-amber-400\"><Crown size={24} /></div>\n",
        "            <div>\n",
        "              <h1 className=\"text-2xl font-serif font-black tracking-tighter\">沐勤 <span className=\"font-light tracking-widest text-lg opacity-50 uppercase\">Muqin</span></h1>\n",
        "              <p className=\"text-[9px] font-bold uppercase tracking-widest opacity-40 italic\">Boutique Interior Quoting System</p>\n",
        "            </div>\n",
        "          </div>\n",
        "          <div className=\"flex gap-2 relative\" ref={saveMenuRef}>\n",
        "             <button onClick={() => setViewMode(viewMode === 'settings' ? 'quote' : 'settings')} className=\"px-4 py-2 rounded-xl text-[11px] font-black border-2 flex items-center gap-2\"><Settings size={14} /> 設定</button>\n",
        "             <button onClick={() => window.print()} className=\"px-4 py-2 rounded-xl text-[11px] font-black border-2 border-stone-800 flex items-center gap-2\"><Printer size={14} /> 列印</button>\n",
        "             <div className=\"relative\">\n",
        "                <button onClick={() => setIsSaveMenuOpen(!isSaveMenuOpen)} className=\"px-6 py-2 rounded-xl text-[11px] font-black bg-stone-800 text-white shadow-lg flex items-center gap-2\">\n",
        "                  <Save size={14} /> 儲存與匯出 <ChevronDown size={14} className={isSaveMenuOpen ? 'rotate-180' : ''} />\n",
        "                </button>\n",
        "                {isSaveMenuOpen && (\n",
        "                  <div className=\"absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-2xl border border-neutral-100 overflow-hidden z-50\">\n",
        "                    <button onClick={handleSaveDraft} className=\"w-full px-4 py-3 text-left text-[11px] font-black hover:bg-neutral-50 flex items-center gap-2\"><CloudUpload size={14} className=\"text-blue-500\"/> 儲存雲端草稿</button>\n",
        "                    <button onClick={() => { setIsSaveMenuOpen(false); window.print(); }} className=\"w-full px-4 py-3 text-left text-[11px] font-black hover:bg-neutral-50 flex items-center gap-2\"><FileType size={14} className=\"text-red-500\"/> 轉存 PDF 報價</button>\n",
        "                    <button onClick={handleExportJSON} className=\"w-full px-4 py-3 text-left text-[11px] font-black hover:bg-neutral-50 flex items-center gap-2\"><Download size={14} className=\"text-green-500\"/> 下載備份 (.json)</button>\n",
        "                  </div>\n",
        "                )}\n",
        "             </div>\n",
        "          </div>\n",
        "        </div>\n",
        "\n",
        "        {/* 狀態提示 */}\n",
        "        {saveStatus.show && (\n",
        "          <div className=\"fixed top-8 right-8 z-[300] animate-in slide-in-from-right-8 fade-in duration-300\">\n",
        "            <div className={`p-4 rounded-xl shadow-2xl flex items-center gap-4 border-2 ${saveStatus.type === 'loading' ? 'bg-white border-neutral-100' : saveStatus.type === 'success' ? 'bg-green-50 border-green-200 text-green-800' : 'bg-red-50 border-red-200 text-red-800'}`}>\n",
        "              {saveStatus.type === 'loading' ? <Loader2 className=\"animate-spin\" size={16} /> : <CheckCircle2 size={16} />}\n",
        "              <span className=\"text-[10px] font-black tracking-widest\">{saveStatus.msg}</span>\n",
        "              <button onClick={() => setSaveStatus(p => ({ ...p, show: false }))}><X size={14} /></button>\n",
        "            </div>\n",
        "          </div>\n",
        "        )}\n",
        "\n",
        "        {viewMode === 'settings' ? (\n",
        "          <div className=\"bg-white p-8 rounded-b-2xl shadow-lg border-x border-b animate-in fade-in\">\n",
        "             <h2 className=\"text-xl font-serif font-black uppercase mb-6 flex items-center gap-3\"><Package size={20}/> 御馨價目表對帳 (115/04/26 生效)</h2>\n",
        "             <div className=\"overflow-x-auto rounded-xl border\">\n",
        "               <table className=\"w-full text-xs text-center\">\n",
        "                 <thead className=\"bg-stone-800 text-white text-[10px] tracking-widest uppercase\">\n",

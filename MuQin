        "                            <div><BilingualLabel cn=\"高\" en=\"H\" /><input type=\"number\" className=\"w-full border-b font-serif font-bold text-lg outline-none\" value={cab.h} onChange={e=>updateCabinet(cab.id, 'h', Number(e.target.value))} /></div>\n",
        "                          </div>\n",
        "                          <select className=\"w-full border-b font-bold text-xs py-2 bg-transparent outline-none\" value={cab.type} onChange={e=>updateCabinet(cab.id, 'type', e.target.value)}>{CABINET_TYPES.map(t=><option key={t.id} value={t.id}>{t.name}</option>)}</select>\n",
